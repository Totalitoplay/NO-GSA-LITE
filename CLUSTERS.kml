<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Visualizador de Clusters · Consulta de Cobertura</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <style>
        :root {
            --accent: #059669;
            --accent-dark: #047857;
            --accent-soft: rgba(5, 150, 105, 0.14);
            --ink: #0f172a;
            --ink-muted: #64748b;
            --panel-bg: rgba(255, 255, 255, 0.88);
            --panel-bg-solid: #ffffff;
            --panel-border: rgba(15, 23, 42, 0.08);
            --hairline: rgba(15, 23, 42, 0.09);
            --shadow: 0 12px 32px -12px rgba(15, 23, 42, 0.22), 0 2px 8px rgba(15, 23, 42, 0.06);
            --shadow-sm: 0 4px 14px -4px rgba(15, 23, 42, 0.18);
            --radius-lg: 18px;
            --radius-md: 12px;
            --radius-sm: 8px;
            --font-base: 13.5px;
            --danger: #dc2626;
        }

        * { box-sizing: border-box; }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: var(--font-base);
            background-color: #eef1f4;
            overflow: hidden;
            color: var(--ink);
        }

        .mono { font-family: 'IBM Plex Mono', monospace; }

        #mapa {
            width: 100%;
            height: 100vh;
            position: absolute;
            inset: 0;
            z-index: 1;
        }

        button { font-family: inherit; }

        /* ============ BARRA SUPERIOR ============ */
        .topbar {
            position: absolute;
            top: 16px;
            left: 16px;
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 4px;
            background: var(--panel-bg);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid var(--panel-border);
            border-radius: 999px;
            padding: 6px;
            box-shadow: var(--shadow);
            max-width: calc(100vw - 32px);
        }

        .icon-btn {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: none;
            background: transparent;
            border-radius: 999px;
            cursor: pointer;
            color: var(--ink-muted);
            transition: all 0.15s ease;
            flex-shrink: 0;
        }

        .icon-btn:hover { background: rgba(15, 23, 42, 0.06); color: var(--ink); }
        .icon-btn.activo { background: var(--accent); color: #fff; }
        .icon-btn svg { width: 18px; height: 18px; }

        .tb-divider {
            width: 1px;
            height: 22px;
            background: var(--hairline);
            margin: 0 2px;
            flex-shrink: 0;
        }

        .coord-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            border: none;
            background: rgba(15, 23, 42, 0.04);
            border-radius: 999px;
            padding: 8px 14px;
            cursor: pointer;
            color: var(--ink);
            font-size: var(--font-base);
            transition: all 0.15s ease;
            min-width: 0;
        }

        .coord-chip:hover { background: rgba(15, 23, 42, 0.08); }
        .coord-chip svg { width: 16px; height: 16px; color: var(--ink-muted); flex-shrink: 0; }
        #chip-coords {
            font-family: 'IBM Plex Mono', monospace;
            font-size: calc(var(--font-base) - 1px);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 220px;
        }

        .brand-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px 8px 8px;
            color: var(--ink);
            font-weight: 600;
            font-size: var(--font-base);
            white-space: nowrap;
        }
        .brand-chip .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }

        .font-ctrl { display: flex; gap: 2px; padding-right: 2px; }
        .font-ctrl button {
            width: 30px; height: 30px;
            border: none; background: transparent;
            border-radius: 999px; cursor: pointer;
            color: var(--ink-muted); font-weight: 700;
            font-size: 11px;
        }
        .font-ctrl button:hover { background: rgba(15,23,42,0.06); color: var(--ink); }

        /* ============ PANELES DESPLEGABLES ============ */
        .panel-flotante {
            position: absolute;
            z-index: 999;
            width: 320px;
            background: var(--panel-bg);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid var(--panel-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            padding: 16px;
            display: none;
            max-height: 70vh;
            overflow-y: auto;
        }
        .panel-flotante.show {
            display: block;
            animation: slideDown 0.22s cubic-bezier(0.4, 0, 0.2, 1);
        }
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        #search-panel { top: 66px; left: 16px; }
        #bookmarks-panel { top: 66px; left: 16px; }
        #layers-panel { top: 66px; right: 16px; }

        .panel-titulo {
            font-size: 12px;
            font-weight: 700;
            color: var(--ink-muted);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin: 0 0 10px 0;
        }

        /* Buscador */
        .busqueda-container { display: flex; gap: 8px; margin-bottom: 12px; }
        .input-texto {
            flex-grow: 1;
            padding: 10px 14px;
            border: 1px solid rgba(0, 0, 0, 0.08);
            background: rgba(255, 255, 255, 0.85);
            border-radius: var(--radius-md);
            font-family: inherit;
            font-size: calc(var(--font-base) - 0.5px);
            color: var(--ink);
            outline: none;
            transition: all 0.2s ease;
            min-width: 0;
        }
        .input-texto:focus {
            border-color: var(--accent);
            background: #fff;
            box-shadow: 0 0 0 3px var(--accent-soft);
        }
        .hint-formato {
            font-size: 10.5px;
            color: var(--ink-muted);
            margin: -6px 0 12px 2px;
            line-height: 1.5;
        }
        .btn-accion {
            padding: 10px 16px;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 600;
            font-size: calc(var(--font-base) - 0.5px);
            cursor: pointer;
            transition: all 0.2s ease;
            flex-shrink: 0;
        }
        .btn-accion:hover { background: var(--accent-dark); transform: translateY(-1px); }

        .panel-resultados { display: none; }
        .panel-resultados.visible {
            display: block;
            background: rgba(15, 23, 42, 0.03);
            border-radius: var(--radius-md);
            padding: 12px;
            border: 1px solid var(--hairline);
            animation: slideDown 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .resultado-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; gap: 8px; }
        .resultado-item:last-child { margin-bottom: 0; }
        .resultado-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
        .resultado-label { font-size: 10.5px; font-weight: 700; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.05em; }
        .resultado-valor { font-size: 12.5px; font-family: 'IBM Plex Mono', monospace; color: var(--ink); font-weight: 500; overflow-wrap: anywhere; }
        .btn-copiar {
            background: transparent; border: none; cursor: pointer; padding: 6px;
            border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center;
            transition: all 0.2s ease; color: var(--ink-muted); flex-shrink: 0;
        }
        .btn-copiar:hover { background: rgba(0, 0, 0, 0.06); color: var(--accent); }
        .btn-copiar svg { width: 16px; height: 16px; }

        /* Toast */
        .toast-copiado {
            position: absolute;
            bottom: 56px;
            left: 50%;
            transform: translateX(-50%) translateY(40px);
            z-index: 2000;
            background: var(--ink);
            color: white;
            padding: 10px 20px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 500;
            box-shadow: 0 10px 25px rgba(0,0,0,0.25);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            opacity: 0;
            pointer-events: none;
        }
        .toast-copiado.show { transform: translateX(-50%) translateY(0); opacity: 1; }

        /* Selector de estilos de mapa */
        .estilo-lista { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 4px; }
        .estilo-opcion {
            flex: 1 1 45%;
            text-align: center;
            padding: 8px 4px;
            font-size: 11.5px;
            font-weight: 600;
            color: var(--ink-muted);
            cursor: pointer;
            border-radius: var(--radius-sm);
            border: 1px solid var(--hairline);
            background: rgba(255,255,255,0.5);
            transition: all 0.15s ease;
        }
        .estilo-opcion.activa { background: var(--accent); color: #fff; border-color: var(--accent); }
        .estilo-opcion:not(.activa):hover { background: rgba(15,23,42,0.05); }

        .layers-panel-section { margin-bottom: 16px; }
        .layers-panel-section:last-child { margin-bottom: 0; }
        .switch-fila { display: flex; align-items: center; gap: 8px; font-size: 12.5px; color: var(--ink); margin-bottom: 8px; cursor: pointer; }

        /* Marcadores guardados */
        .bookmarks-panel-header { display: flex; gap: 6px; margin-bottom: 12px; }
        .marcador-fila {
            display: flex; align-items: center; justify-content: space-between;
            padding: 8px 10px; border-radius: var(--radius-sm);
            background: rgba(15,23,42,0.03); margin-bottom: 6px;
        }
        .marcador-nombre {
            background: none; border: none; text-align: left; flex-grow: 1;
            font-size: 12.5px; color: var(--ink); cursor: pointer; padding: 0;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }
        .marcador-nombre:hover { color: var(--accent); }
        .marcador-borrar {
            background: none; border: none; color: var(--ink-muted); cursor: pointer;
            font-size: 13px; padding: 2px 6px; border-radius: 6px; flex-shrink: 0;
        }
        .marcador-borrar:hover { color: var(--danger); background: rgba(220,38,38,0.08); }
        .vacio { font-size: 12px; color: var(--ink-muted); text-align: center; padding: 16px 4px; }

        /* ============ RIEL DE HERRAMIENTAS (DERECHA) ============ */
        .right-rail {
            position: absolute;
            top: 16px;
            right: 16px;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 2px;
            background: var(--panel-bg);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid var(--panel-border);
            border-radius: var(--radius-lg);
            padding: 6px;
            box-shadow: var(--shadow);
        }

        /* Banner de modo activo (medir / marcar) */
        .mode-banner {
            position: absolute;
            top: 16px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1000;
            display: none;
            align-items: center;
            gap: 12px;
            background: var(--ink);
            color: #fff;
            padding: 10px 16px;
            border-radius: 999px;
            font-size: 12.5px;
            box-shadow: var(--shadow);
        }
        .mode-banner.show { display: flex; }
        .mode-banner .mono { color: #a7f3d0; font-weight: 600; }
        .mode-banner button {
            background: rgba(255,255,255,0.15); border: none; color: #fff;
            padding: 5px 10px; border-radius: 999px; cursor: pointer; font-size: 11.5px;
        }
        .mode-banner button:hover { background: rgba(255,255,255,0.25); }

        /* Tooltips de medición */
        .tooltip-medicion {
            background: var(--ink) !important;
            color: #fff !important;
            border: none !important;
            box-shadow: var(--shadow-sm);
            font-family: 'IBM Plex Mono', monospace;
            font-size: 11px;
            padding: 3px 7px;
        }
        .tooltip-medicion::before { display: none; }

        /* ============ BARRA DE ESTADO INFERIOR ============ */
        .statusbar {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            z-index: 1000;
            height: 30px;
            display: flex;
            align-items: center;
            padding: 0 14px;
            gap: 16px;
            background: var(--panel-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-top: 1px solid var(--panel-border);
            font-size: 11px;
            color: var(--ink-muted);
        }
        #status-left {
            font-family: 'IBM Plex Mono', monospace;
            cursor: pointer;
            color: var(--ink);
            user-select: none;
        }
        #status-left:hover { color: var(--accent); }
        .status-sep { opacity: 0.5; }
        .status-mid { display: flex; align-items: center; gap: 10px; font-family: 'IBM Plex Mono', monospace; }
        .status-right { margin-left: auto; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* Controles nativos de Leaflet */
        .leaflet-bottom.leaflet-left { bottom: 38px; }
        .leaflet-control-scale { margin-bottom: 4px !important; }
        .leaflet-control-scale-line {
            background: var(--panel-bg) !important;
            backdrop-filter: blur(8px);
            border: 1px solid var(--panel-border) !important;
            color: var(--ink) !important;
            font-family: 'IBM Plex Mono', monospace;
        }
        .leaflet-bar {
            border: none !important;
            box-shadow: var(--shadow-sm) !important;
            border-radius: var(--radius-md) !important;
            overflow: hidden;
        }
        .leaflet-bar a {
            background: var(--panel-bg) !important;
            backdrop-filter: blur(8px);
            color: var(--ink) !important;
            border-bottom: 1px solid var(--panel-border) !important;
        }
        .leaflet-bar a:hover { background: rgba(15,23,42,0.06) !important; }

        /* Popups personalizados */
        .popup-contenido { font-size: 12px; min-width: 190px; }
        .popup-fila { margin-bottom: 6px; }
        .popup-btn-eliminar {
            width: 100%; margin-top: 4px; padding: 6px 10px;
            background: rgba(220,38,38,0.08); color: var(--danger);
            border: none; border-radius: 8px; cursor: pointer; font-size: 11.5px; font-weight: 600;
        }
        .popup-btn-eliminar:hover { background: rgba(220,38,38,0.15); }
        .btn-copiar-mini {
            background: transparent; border: none; cursor: pointer; padding: 4px;
            border-radius: var(--radius-sm); display: inline-flex; align-items: center; justify-content: center;
            transition: all 0.2s ease; color: var(--ink-muted); flex-shrink: 0; margin-left: auto;
        }
        .btn-copiar-mini:hover { background: rgba(0, 0, 0, 0.06); color: var(--accent); }
        .btn-copiar-mini svg { width: 14px; height: 14px; }

        @media print {
            .topbar, .right-rail, .panel-flotante, .mode-banner, .statusbar,
            .leaflet-control-zoom, .leaflet-control-scale, #toast { display: none !important; }
            #mapa { position: static; height: 100vh; }
        }

        @media (max-width: 640px) {
            #chip-coords { max-width: 110px; }
            .panel-flotante { width: calc(100vw - 32px); }
            .brand-chip span:not(.dot) { display: none; }
        }
        /* Estilo del marcador tipo Google Maps */
        .marker-google-style {
            width: 24px !important;
            height: 24px !important;
            margin-left: -12px !important;
            margin-top: -12px !important;
            border-radius: 50%;
            background-color: #fbbc05;
            border: 3px solid #ffffff;
            box-shadow: 0 0 4px rgba(0,0,0,0.4);
            pointer-events: none;
        }
    </style>
</head>
<body>

    <div class="topbar">
        <button class="icon-btn" id="btn-locate" title="Mi ubicación">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3M12 19v3M2 12h3M19 12h3"></path></svg>
        </button>
        <div class="tb-divider"></div>
        <button class="coord-chip" id="btn-toggle-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="M21 21l-4.35-4.35"></path></svg>
            <span id="chip-coords">Buscar coordenadas o Plus Code…</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>
        </button>
        <div class="tb-divider"></div>
        <button class="icon-btn" id="btn-bookmarks" title="Marcadores guardados">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.62L12 2 9.19 8.62 2 9.24l5.46 4.73L5.82 21z"></path></svg>
        </button>
        <button class="icon-btn" id="btn-home" title="Vista inicial">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path><path d="M9 22V12h6v10"></path></svg>
        </button>
        <div class="tb-divider"></div>
        <div class="brand-chip"><span class="dot"></span><span>Visualizador de Clusters</span></div>
        <div class="tb-divider"></div>
        <div class="font-ctrl">
            <button id="font-dec" title="Reducir tamaño de texto">A-</button>
            <button id="font-inc" title="Aumentar tamaño de texto">A+</button>
        </div>
    </div>

    <div class="panel-flotante" id="search-panel">
        <p class="panel-titulo">Buscar ubicación</p>
        <div class="busqueda-container">
            <input type="text" id="buscador-input" class="input-texto" placeholder="Ej. 31.735, -106.481">
            <button id="btn-buscar" class="btn-accion">Buscar</button>
        </div>
        <div class="hint-formato">Acepta decimal, DMS (31°44'06.0"N 106°28'51.6"W), Plus Code o UTM (13S 350000 3512000).</div>

        <div id="panel-info" class="panel-resultados">
            <div class="resultado-item">
                <div class="resultado-info"><span class="resultado-label">Decimal</span><span id="info-decimal" class="resultado-valor">-</span></div>
                <button class="btn-copiar" onclick="copiarTexto('info-decimal')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></button>
            </div>
            <div class="resultado-item">
                <div class="resultado-info"><span class="resultado-label">Grados DMS</span><span id="info-dms" class="resultado-valor">-</span></div>
                <button class="btn-copiar" onclick="copiarTexto('info-dms')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></button>
            </div>
            <div class="resultado-item">
                <div class="resultado-info"><span class="resultado-label">Plus Code</span><span id="info-plus" class="resultado-valor">-</span></div>
                <button class="btn-copiar" onclick="copiarTexto('info-plus')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></button>
            </div>
            <div class="resultado-item">
                <div class="resultado-info"><span class="resultado-label">UTM</span><span id="info-utm" class="resultado-valor">-</span></div>
                <button class="btn-copiar" onclick="copiarTexto('info-utm')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></button>
            </div>
        </div>
    </div>

    <div class="panel-flotante" id="bookmarks-panel">
        <p class="panel-titulo">Marcadores guardados</p>
        <div class="bookmarks-panel-header">
            <input type="text" id="nombre-marcador-input" class="input-texto" placeholder="Nombre de la vista actual…">
            <button id="btn-agregar-marcador" class="btn-accion">Guardar</button>
        </div>
        <div id="lista-marcadores"></div>
    </div>

    <div class="panel-flotante" id="layers-panel">
        <div class="layers-panel-section">
            <p class="panel-titulo">Estilo de mapa</p>
            <div class="estilo-lista">
                <button class="estilo-opcion activa" data-estilo="google">Google Maps</button>
                <button class="estilo-opcion" data-estilo="satelite">Satélite</button>
                <button class="estilo-opcion" data-estilo="topografico">Topográfico</button>
                <button class="estilo-opcion" data-estilo="calles">Calles (OSM)</button>
            </div>
        </div>
        <div class="layers-panel-section">
            <p class="panel-titulo">Capa de clusters (KML)</p>
            <label class="switch-fila"><input type="checkbox" id="toggle-kml" checked> Mostrar clusters</label>
        </div>
    </div>

    <div class="right-rail">
        <button class="icon-btn" id="btn-layers" title="Capas del mapa">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
        </button>
        <button class="icon-btn" id="btn-measure" title="Medir distancia">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20l18-18M8 14l2 2M12 10l2 2M16 6l2 2"></path></svg>
        </button>
        <button class="icon-btn" id="btn-draw" title="Colocar marcador">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"></path><path d="M18.5 2.5a2.12 2.12 0 013 3L12 15l-4 1 1-4z"></path></svg>
        </button>
        <button class="icon-btn" id="btn-fullscreen" title="Pantalla completa">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 00-2 2v3M16 3h3a2 2 0 012 2v3M21 16v3a2 2 0 01-2 2h-3M8 21H5a2 2 0 01-2-2v-3"></path></svg>
        </button>
        <button class="icon-btn" id="btn-print" title="Imprimir mapa">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
        </button>
    </div>

    <div class="mode-banner" id="mode-banner">
        <span id="mode-banner-text">Modo activo</span>
        <span id="measure-total" class="mono">0 m</span>
        <button id="btn-deshacer-medicion">Deshacer</button>
        <button id="btn-limpiar-modo">Limpiar</button>
        <button id="btn-salir-modo">Salir</button>
    </div>

    <div class="statusbar">
        <span id="status-left" title="Clic para alternar Lat/Lng ↔ Mercator">-- (Mouse)</span>
        <span class="status-sep">|</span>
        <span id="status-crs">WGS 84 / Pseudo-Mercator (EPSG:3857)</span>
        <div class="status-mid">
            <span id="status-zoom">Zoom 13</span>
        </div>
        <span class="status-right" id="status-right">© Google</span>
    </div>

    <div id="toast" class="toast-copiado">¡Copiado al portapapeles!</div>

    <div id="mapa"></div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-kml@1.0.0/L.KML.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/openlocationcode/1.0.4/openlocationcode.min.js"></script>
    <script src="https://unpkg.com/proj4@2.9.0/dist/proj4.js"></script>
    
    <script>
        /* ==================================================================
           1. CAPAS BASE
           ================================================================== */
        var CENTRO_INICIAL = [31.735, -106.481];
        var ZOOM_INICIAL = 13;

        var capaGoogle = L.tileLayer('https://mt1.google.com/vt/lyrs=m&x={x}&y={y}&z={z}', {
            maxZoom: 20, attribution: '© Google'
        });

        var capaSatelite = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
            maxZoom: 19, attribution: 'Esri, Maxar, Earthstar Geographics'
        });

        var capaTopografico = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
            maxZoom: 17, attribution: '© OpenTopoMap (CC-BY-SA)'
        });
        var capaCalles = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19, attribution: '© OpenStreetMap contributors'
        });

        var CAPAS = { google: capaGoogle, satelite: capaSatelite, topografico: capaTopografico, calles: capaCalles };
        var ATRIBUCIONES = {
            google: '© Google',
            satelite: 'Esri, Maxar, Earthstar Geographics',
            topografico: '© OpenTopoMap (CC-BY-SA)',
            calles: '© OpenStreetMap contributors'
        };
        var ESTILOS_OSCUROS = new Set(['satelite']);

        /* NOTA: Se añadió un renderer explícito con padding amplio (1.5) para evitar cortes de geometría pesada */
        var map = L.map('mapa', {
            center: CENTRO_INICIAL,
            zoom: ZOOM_INICIAL,
            zoomControl: false,
            attributionControl: false,
            layers: [capaGoogle],
            renderer: L.canvas({ padding: 1.5, tolerance: 5 })
        });

        L.control.zoom({ position: 'bottomleft' }).addTo(map);
        L.control.scale({ position: 'bottomleft', metric: true, imperial: false }).addTo(map);

        function cambiarMapa(tipo) {
            Object.values(CAPAS).forEach(function (c) { if (map.hasLayer(c)) map.removeLayer(c); });
            map.addLayer(CAPAS[tipo]);
            document.querySelectorAll('.estilo-opcion').forEach(function (el) {
                el.classList.toggle('activa', el.dataset.estilo === tipo);
            });
            document.getElementById('status-right').textContent = ATRIBUCIONES[tipo];
            cambiarColoresInterfaz(ESTILOS_OSCUROS.has(tipo));
        }
        document.querySelectorAll('.estilo-opcion').forEach(function (btn) {
            btn.addEventListener('click', function () { cambiarMapa(btn.dataset.estilo); });
        });
        cambiarMapa('google');

        function cambiarColoresInterfaz(isDarkMap) {
            var root = document.documentElement;
            if (isDarkMap) {
                root.style.setProperty('--panel-bg', 'rgba(17, 24, 39, 0.86)');
                root.style.setProperty('--panel-border', 'rgba(255, 255, 255, 0.1)');
                root.style.setProperty('--hairline', 'rgba(255, 255, 255, 0.12)');
                root.style.setProperty('--ink', '#F9FAFB');
                root.style.setProperty('--ink-muted', '#9CA3AF');
            } else {
                root.style.setProperty('--panel-bg', 'rgba(255, 255, 255, 0.88)');
                root.style.setProperty('--panel-border', 'rgba(15, 23, 42, 0.08)');
                root.style.setProperty('--hairline', 'rgba(15, 23, 42, 0.09)');
                root.style.setProperty('--ink', '#0f172a');
                root.style.setProperty('--ink-muted', '#64748b');
            }
        }

        /* ==================================================================
           2. PANELES DESPLEGABLES
           ================================================================== */
        var IDS_PANELES = ['search-panel', 'bookmarks-panel', 'layers-panel'];
        function cerrarTodosPaneles() {
            IDS_PANELES.forEach(function (id) { document.getElementById(id).classList.remove('show'); });
        }
        function togglePanel(id) {
            var el = document.getElementById(id);
            var abierto = el.classList.contains('show');
            cerrarTodosPaneles();
            if (!abierto) el.classList.add('show');
        }

        document.getElementById('btn-toggle-search').addEventListener('click', function () { togglePanel('search-panel'); });
        document.getElementById('btn-bookmarks').addEventListener('click', function () { togglePanel('bookmarks-panel'); renderMarcadores(); });
        document.getElementById('btn-layers').addEventListener('click', function () { togglePanel('layers-panel'); });

        document.getElementById('btn-home').addEventListener('click', function () {
            map.setView(CENTRO_INICIAL, ZOOM_INICIAL);
        });

        document.getElementById('btn-locate').addEventListener('click', function () {
            if (!navigator.geolocation) { alert('Tu navegador no soporta geolocalización.'); return; }
            navigator.geolocation.getCurrentPosition(function (pos) {
                var lat = pos.coords.latitude, lng = pos.coords.longitude;
                map.setView([lat, lng], 16);
                marcadorBusqueda.setLatLng([lat, lng]);
                if (!map.hasLayer(marcadorBusqueda)) map.addLayer(marcadorBusqueda);
                actualizarPanelInfo(lat, lng);
            }, function () {
                alert('No se pudo obtener tu ubicación.');
            });
        });

        document.getElementById('btn-fullscreen').addEventListener('click', function () {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(function () {});
            } else {
                document.exitFullscreen();
            }
        });

        document.getElementById('btn-print').addEventListener('click', function () { window.print(); });

        var escalaFuente = parseFloat(localStorage.getItem('clusters_font_scale')) || 13.5;
        function aplicarEscalaFuente() { document.documentElement.style.setProperty('--font-base', escalaFuente + 'px'); }
        document.getElementById('font-dec').addEventListener('click', function () {
            escalaFuente = Math.max(11, escalaFuente - 1); aplicarEscalaFuente();
            localStorage.setItem('clusters_font_scale', escalaFuente);
        });
        document.getElementById('font-inc').addEventListener('click', function () {
            escalaFuente = Math.min(18, escalaFuente + 1); aplicarEscalaFuente();
            localStorage.setItem('clusters_font_scale', escalaFuente);
        });
        aplicarEscalaFuente();

        /* ==================================================================
           3. CAPA KML DE CLUSTERS
           ================================================================== */
        var capaKml = new L.FeatureGroup();
        map.addLayer(capaKml);

        /*
           Esta función:
           1) Extrae el nombre real del Placemark (desde feature.properties.name o desde el
              popup nativo que arma leaflet-kml) y lo HEREDA hacia las capas hijas, porque en
              muchos KML el popup con el nombre queda en el grupo contenedor del Placemark y
              no en la geometría "hoja" (Polygon/Marker) que es la que realmente recibe el clic.
           2) Sólo engancha el manejador de clic interactivo (el que respeta modoActivo) en las
              capas "hoja" (L.Marker o L.Path: Polygon/Polyline/Circle/Rectangle), NUNCA en
              grupos (L.LayerGroup/L.FeatureGroup). Antes también se enganchaba en los grupos
              porque L.FeatureGroup expone setStyle, y como Leaflet reenvía los eventos de sus
              hijos hacia el grupo, un solo clic disparaba DOS manejadores (uno con el nombre
              correcto y otro con "Cluster" por defecto), y en modo medición uno de los dos
              seguía abriendo el popup del cluster en lugar de solo agregar el punto.
        */
        function procesarCapasKML(layer, nombreHeredado) {
            var nombreActual = nombreHeredado;

            // Intentar extraer un nombre propio en este nivel (antes de destruir nada)
            if (layer.feature && layer.feature.properties && layer.feature.properties.name) {
                nombreActual = layer.feature.properties.name;
            } else if (typeof layer.getPopup === 'function' && layer.getPopup()) {
                nombreActual = layer.getPopup().getContent();
            }

            if (nombreActual != null) {
                nombreActual = String(nombreActual).replace(/<[^>]*>/g, '').trim();
            }

            // Quitamos el popup nativo en este nivel para que no interfiera (se use o no el nombre)
            if (typeof layer.unbindPopup === 'function') {
                layer.unbindPopup();
            }

            // Recursión: heredamos hacia los hijos el nombre encontrado hasta ahora
            if (layer.eachLayer) {
                layer.eachLayer(function (hijo) {
                    procesarCapasKML(hijo, nombreActual);
                });
            }

            // Sólo las formas finales reciben el manejador de clic interactivo.
            // Se excluyen explícitamente los grupos, aunque tengan setStyle.
            var esHoja = (layer instanceof L.Marker) || (layer instanceof L.Path);
            if (esHoja) {
                layer._nombreCluster = nombreActual || 'Cluster';

                layer.off('click');
                layer.on('click', function (e) {
                    L.DomEvent.stop(e);

                    if (modoActivo === 'measure') {
                        map.closePopup();
                        addMeasurePoint(e.latlng);
                        return;
                    }
                    if (modoActivo === 'draw') {
                        map.closePopup();
                        addCustomMarker(e.latlng);
                        return;
                    }

                    // Solo abre este popup si no hay ninguna herramienta activa
                    L.popup({ autoPan: false })
                        .setLatLng(e.latlng)
                        .setContent('<b>' + layer._nombreCluster + '</b>')
                        .openOn(map);
                });
            }
        }

        fetch('CLUSTERS.kml')
            .then(function (res) { return res.text(); })
            .then(function (kmltext) {
                var parser = new DOMParser();
                var kml = parser.parseFromString(kmltext, 'text/xml');
                var track = new L.KML(kml);

                procesarCapasKML(track);
                capaKml.addLayer(track);

                var limites = track.getBounds();
                if (limites.isValid()) map.fitBounds(limites);
            })
            .catch(function (err) {
                console.error('Error cargando KML:', err);
            });

        document.getElementById('toggle-kml').addEventListener('change', function (e) {
            if (!capaKml) return;
            if (e.target.checked) { if (!map.hasLayer(capaKml)) map.addLayer(capaKml); }
            else { if (map.hasLayer(capaKml)) map.removeLayer(capaKml); }
        });

        /* ==================================================================
           4. MARCADOR DE BÚSQUEDA (solo aparece al buscar coordenadas)
           ================================================================== */
        var iconGoogle = L.divIcon({
            className: 'marker-google-style',
            html: '',
            iconSize: [24, 24],
            iconAnchor: [12, 12]
        });

        var marcadorBusqueda = L.marker([0, 0], { icon: iconGoogle }).addTo(map);
        map.removeLayer(marcadorBusqueda);

        /* ==================================================================
           5. CONVERSIÓN DE COORDENADAS (Decimal / DMS / Plus Code / UTM)
           ================================================================== */
        function decimalToDMS(dd, isLat) {
            var dir = dd < 0 ? (isLat ? 'S' : 'W') : (isLat ? 'N' : 'E');
            var absDd = Math.abs(dd);
            var deg = Math.floor(absDd);
            var minFrac = (absDd - deg) * 60;
            var min = Math.floor(minFrac);
            var sec = ((minFrac - min) * 60).toFixed(2);
            return deg + '° ' + min + "' " + sec + '" ' + dir;
        }

        function dmsToDecimal(degrees, minutes, seconds, direction) {
            var dd = parseFloat(degrees) + parseFloat(minutes) / 60 + parseFloat(seconds) / 3600;
            if (['S', 'W', 'O'].includes(direction.toUpperCase())) dd = dd * -1;
            return dd;
        }

        var BANDAS_UTM = 'CDEFGHJKLMNPQRSTUVWXX';
        function obtenerBandaUTM(lat) {
            if (lat < -80 || lat > 84) return 'Z';
            var idx = Math.floor((lat + 80) / 8);
            return BANDAS_UTM[Math.min(Math.max(idx, 0), BANDAS_UTM.length - 1)];
        }

        function parseUTM(texto) {
            if (typeof proj4 === 'undefined') return null;
            var m = texto.trim().match(/^(\d{1,2})\s*([A-HJ-NP-Za-hj-np-z])[\s,]+(\d+(?:\.\d+)?)[\s,]+(\d+(?:\.\d+)?)$/);
            if (!m) return null;
            var zona = parseInt(m[1], 10);
            var banda = m[2].toUpperCase();
            var este = parseFloat(m[3]);
            var norte = parseFloat(m[4]);
            if (zona < 1 || zona > 60) return null;
            var esSur = banda < 'N';
            var def = '+proj=utm +zone=' + zona + ' +datum=WGS84 +units=m +no_defs' + (esSur ? ' +south' : '');
            try {
                var res = proj4(def, 'WGS84', [este, norte]);
                return { lat: res[1], lng: res[0] };
            } catch (e) { return null; }
        }

        function calcularUTM(lat, lng) {
            if (typeof proj4 === 'undefined') return null;
            var zona = Math.floor((lng + 180) / 6) + 1;
            var esSur = lat < 0;
            var def = '+proj=utm +zone=' + zona + ' +datum=WGS84 +units=m +no_defs' + (esSur ? ' +south' : '');
            try {
                var res = proj4('WGS84', def, [lng, lat]);
                var banda = obtenerBandaUTM(lat);
                return zona + banda + ' ' + Math.round(res[0]) + ' ' + Math.round(res[1]);
            } catch (e) { return null; }
        }

        function procesarEntrada(texto) {
            texto = texto.trim();

            if (texto.includes('+')) {
                var matchPlusCode = texto.match(/[23456789CFGHJMPQRVWX]{2,8}\+[23456789CFGHJMPQRVWX]{0,4}/i);
                if (matchPlusCode) {
                    var codigoLimpio = matchPlusCode[0].toUpperCase();
                    try {
                        if (OpenLocationCode.isShort(codigoLimpio)) {
                            var centro = map.getCenter();
                            codigoLimpio = OpenLocationCode.recoverNearest(codigoLimpio, centro.lat, centro.lng);
                        }
                        if (OpenLocationCode.isValid(codigoLimpio) && OpenLocationCode.isFull(codigoLimpio)) {
                            var decodificado = OpenLocationCode.decode(codigoLimpio);
                            return { lat: decodificado.latitudeCenter, lng: decodificado.longitudeCenter };
                        }
                    } catch (e) {
                        console.error("Error al procesar el Plus Code:", e);
                    }
                }
            }

            var utm = parseUTM(texto);
            if (utm) return utm;

            var regexDMS = /(\d+(?:\.\d+)?)[°\s]+(\d+(?:\.\d+)?)[′'’\s]+(\d+(?:\.\d+)?)[″"”\s]*([NSEWO])/gi;
            var matches = [...texto.matchAll(regexDMS)];
            if (matches.length === 2) {
                var lat = dmsToDecimal(matches[0][1], matches[0][2], matches[0][3], matches[0][4]);
                var lng = dmsToDecimal(matches[1][1], matches[1][2], matches[1][3], matches[1][4]);
                return { lat: lat, lng: lng };
            }

            var cleanStr = texto.replace(/[,;°]/g, ' '); 
            var partes = cleanStr.trim().split(/\s+/);
            if (partes.length >= 2) {
                var latD = parseFloat(partes[0]);
                var lngD = parseFloat(partes[1]);
                if (!isNaN(latD) && !isNaN(lngD) && latD >= -90 && latD <= 90 && lngD >= -180 && lngD <= 180) {
                    return { lat: latD, lng: lngD };
                }
            }
            return null;
        }

        function actualizarPanelInfo(lat, lng) {
            var dmsLat = decimalToDMS(lat, true);
            var dmsLng = decimalToDMS(lng, false);
            var plusCode = '-';
            try {
                var fullCode = OpenLocationCode.encode(lat, lng);
                plusCode = fullCode.substring(4) + " Juárez, Chihuahua";
            } catch (e) {
                console.error("No se pudo codificar el Plus Code", e);
            }
            var utmTexto = calcularUTM(lat, lng) || 'No disponible';

            document.getElementById('info-decimal').textContent = lat.toFixed(6) + ', ' + lng.toFixed(6);
            document.getElementById('info-dms').textContent = dmsLat + ' ' + dmsLng;
            document.getElementById('info-plus').textContent = plusCode;
            document.getElementById('info-utm').textContent = utmTexto;
            document.getElementById('panel-info').classList.add('visible');
            document.getElementById('chip-coords').textContent = lat.toFixed(6) + ', ' + lng.toFixed(6);
        }

        function ejecutarBusqueda() {
            var input = document.getElementById('buscador-input').value;
            var coordenadas = procesarEntrada(input);

            if (coordenadas) {
                var lat = coordenadas.lat, lng = coordenadas.lng;
                map.setView([lat, lng], 17);
                marcadorBusqueda.setLatLng([lat, lng]);
                if (!map.hasLayer(marcadorBusqueda)) map.addLayer(marcadorBusqueda);
                actualizarPanelInfo(lat, lng);
            } else {
                alert('No se pudo identificar el formato. Comprueba el formato e intenta nuevamente.');
            }
        }

        document.getElementById('btn-buscar').addEventListener('click', ejecutarBusqueda);
        document.getElementById('buscador-input').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') ejecutarBusqueda();
        });

        function copiarTexto(idElemento) {
            var texto = document.getElementById(idElemento).textContent;
            navigator.clipboard.writeText(texto).then(function () {
                var toast = document.getElementById('toast');
                toast.classList.add('show');
                setTimeout(function () { toast.classList.remove('show'); }, 2000);
            });
        }
        
        function copiarTextoDirecto(texto) {
            navigator.clipboard.writeText(texto).then(function () {
                var toast = document.getElementById('toast');
                toast.classList.add('show');
                setTimeout(function () { toast.classList.remove('show'); }, 2000);
            });
        }

        /* ==================================================================
           6. MODOS: MEDIR DISTANCIA / COLOCAR MARCADORES
           ================================================================== */
        var modoActivo = null;

        function setModo(nuevo) {
            modoActivo = (modoActivo === nuevo) ? null : nuevo;
            document.getElementById('btn-measure').classList.toggle('activo', modoActivo === 'measure');
            document.getElementById('btn-draw').classList.toggle('activo', modoActivo === 'draw');
            var banner = document.getElementById('mode-banner');
            var texto = document.getElementById('mode-banner-text');
            var total = document.getElementById('measure-total');
            var btnDeshacer = document.getElementById('btn-deshacer-medicion');
            if (modoActivo === 'measure') {
                banner.classList.add('show');
                texto.textContent = 'Modo medición: clic para agregar puntos, doble clic para terminar';
                total.style.display = 'inline';
                btnDeshacer.style.display = 'inline-block';
                map.doubleClickZoom.disable();
            } else if (modoActivo === 'draw') {
                banner.classList.add('show');
                texto.textContent = 'Modo marcador: clic en el mapa para colocar un pin';
                total.style.display = 'none';
                btnDeshacer.style.display = 'none';
                map.doubleClickZoom.enable();
            } else {
                banner.classList.remove('show');
                map.doubleClickZoom.enable();
            }
            map.getContainer().style.cursor = modoActivo ? 'crosshair' : '';
        }

        document.getElementById('btn-measure').addEventListener('click', function () { setModo('measure'); });
        document.getElementById('btn-draw').addEventListener('click', function () { setModo('draw'); });
        document.getElementById('btn-salir-modo').addEventListener('click', function () { modoActivo = null; setModo(null); });
        document.getElementById('btn-limpiar-modo').addEventListener('click', function () {
            if (modoActivo === 'measure') limpiarMedicion();
        });
        document.getElementById('btn-deshacer-medicion').addEventListener('click', function () {
            if (modoActivo === 'measure') deshacerPuntoMedicion();
        });

        map.on('dblclick', function () {
            if (modoActivo === 'measure') { modoActivo = null; setModo(null); }
        });

        function formatDistancia(m) { return m >= 1000 ? (m / 1000).toFixed(2) + ' km' : m.toFixed(1) + ' m'; }

        var puntosMedicion = [];
        var lineaMedicion = null;
        var marcadoresMedicion = [];
        var tooltipsMedicion = [];

        function redibujarLineaMedicion() {
            if (lineaMedicion) { map.removeLayer(lineaMedicion); lineaMedicion = null; }
            if (puntosMedicion.length > 1) {
                lineaMedicion = L.polyline(puntosMedicion, { color: '#059669', weight: 3, dashArray: '6 6' }).addTo(map);
            }
        }

        function recalcularTotalMedicion() {
            var total = 0;
            for (var i = 1; i < puntosMedicion.length; i++) total += puntosMedicion[i - 1].distanceTo(puntosMedicion[i]);
            document.getElementById('measure-total').textContent = formatDistancia(total);
        }

        function addMeasurePoint(latlng) {
            puntosMedicion.push(latlng);
            var m = L.circleMarker(latlng, { radius: 5, color: '#fff', weight: 2, fillColor: '#059669', fillOpacity: 1 }).addTo(map);
            marcadoresMedicion.push(m);
            redibujarLineaMedicion();

            if (puntosMedicion.length > 1) {
                var a = puntosMedicion[puntosMedicion.length - 2];
                var b = puntosMedicion[puntosMedicion.length - 1];
                var d = a.distanceTo(b);
                var mid = L.latLng((a.lat + b.lat) / 2, (a.lng + b.lng) / 2);
                var tip = L.tooltip({ permanent: true, direction: 'top', className: 'tooltip-medicion' })
                    .setLatLng(mid).setContent(formatDistancia(d));
                tip.addTo(map);
                tooltipsMedicion.push(tip);
            }
            recalcularTotalMedicion();
        }

        function deshacerPuntoMedicion() {
            if (puntosMedicion.length === 0) return;
            puntosMedicion.pop();
            var ultimoMarcador = marcadoresMedicion.pop();
            if (ultimoMarcador) map.removeLayer(ultimoMarcador);
            var ultimoTip = tooltipsMedicion.pop();
            if (ultimoTip) map.removeLayer(ultimoTip);
            redibujarLineaMedicion();
            recalcularTotalMedicion();
        }

        function limpiarMedicion() {
            puntosMedicion = [];
            if (lineaMedicion) { map.removeLayer(lineaMedicion); lineaMedicion = null; }
            marcadoresMedicion.forEach(function (m) { map.removeLayer(m); });
            marcadoresMedicion = [];
            tooltipsMedicion.forEach(function (t) { map.removeLayer(t); });
            tooltipsMedicion = [];
            document.getElementById('measure-total').textContent = '0 m';
        }

        var marcadoresCustom = [];
        var contadorMarcadores = 0;
        
        function generarPopupMarcador(latlng, id) {
            var dms = decimalToDMS(latlng.lat, true) + ' ' + decimalToDMS(latlng.lng, false);
            var plusCode = '-';
            try {
                var fullCode = OpenLocationCode.encode(latlng.lat, latlng.lng);
                plusCode = fullCode.substring(4) + " Juárez, Chihuahua";
            } catch (e) {
                console.error("No se pudo codificar el Plus Code", e);
            }

            var btnHtml = '<button class="btn-copiar-mini" onclick="copiarTextoDirecto(\'' + plusCode + '\')" title="Copiar Plus Code"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg></button>';

            return '<div class="popup-contenido">' +
                '<div class="popup-fila"><b>Decimal:</b><br>' + latlng.lat.toFixed(6) + ', ' + latlng.lng.toFixed(6) + '</div>' +
                '<div class="popup-fila"><b>DMS:</b><br>' + dms + '</div>' +
                '<div class="popup-fila" style="display: flex; align-items: center; justify-content: space-between;">' +
                '<div><b>Plus Code:</b><br>' + plusCode + '</div>' + btnHtml +
                '</div>' +
                '<button class="popup-btn-eliminar" onclick="eliminarMarcador(' + id + ')">Eliminar marcador</button>' +
                '</div>';
        }
        
        function addCustomMarker(latlng) {
            var id = contadorMarcadores++;
            var marker = L.marker(latlng, { draggable: true }).addTo(map);
            marker._idPersonalizado = id;
            marker.bindPopup(generarPopupMarcador(latlng, id)).openPopup();
            marker.on('dragend', function (e) { marker.setPopupContent(generarPopupMarcador(e.target.getLatLng(), id)); });
            marcadoresCustom.push(marker);
        }
        
        function eliminarMarcador(id) {
            var idx = marcadoresCustom.findIndex(function (m) { return m._idPersonalizado === id; });
            if (idx > -1) { map.removeLayer(marcadoresCustom[idx]); marcadoresCustom.splice(idx, 1); }
        }

        /* Clic normal en el mapa: SOLO mide, dibuja o deselecciona un cluster. */
        map.on('click', function (e) {
            if (modoActivo === 'measure') { addMeasurePoint(e.latlng); return; }
            if (modoActivo === 'draw') { addCustomMarker(e.latlng); return; }
            map.closePopup(); 
        });

        /* Mantener presionado (móvil) o clic derecho (PC) para colocar marcador rápido */
        map.on('contextmenu', function (e) {
            addCustomMarker(e.latlng);
        });

        /* ==================================================================
           7. MARCADORES GUARDADOS
           ================================================================== */
        function obtenerMarcadoresGuardados() {
            try { return JSON.parse(localStorage.getItem('clusters_bookmarks') || '[]'); } catch (e) { return []; }
        }
        function guardarMarcadoresGuardados(lista) { localStorage.setItem('clusters_bookmarks', JSON.stringify(lista)); }
        function escaparHtml(s) {
            return String(s).replace(/[&<>"']/g, function (c) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
            });
        }
        function renderMarcadores() {
            var cont = document.getElementById('lista-marcadores');
            var lista = obtenerMarcadoresGuardados();
            if (lista.length === 0) { cont.innerHTML = '<div class="vacio">Sin marcadores guardados</div>'; return; }
            cont.innerHTML = lista.map(function (b, i) {
                return '<div class="marcador-fila">' +
                    '<button class="marcador-nombre" onclick="irAMarcador(' + i + ')">' + escaparHtml(b.nombre) + '</button>' +
                    '<button class="marcador-borrar" onclick="borrarMarcador(' + i + ')" title="Eliminar">✕</button>' +
                    '</div>';
            }).join('');
        }
        function irAMarcador(i) { var b = obtenerMarcadoresGuardados()[i]; if (b) map.setView([b.lat, b.lng], b.zoom); }
        function borrarMarcador(i) { var lista = obtenerMarcadoresGuardados(); lista.splice(i, 1); guardarMarcadoresGuardados(lista); renderMarcadores(); }

        document.getElementById('btn-agregar-marcador').addEventListener('click', function () {
            var input = document.getElementById('nombre-marcador-input');
            var lista = obtenerMarcadoresGuardados();
            var nombre = input.value.trim() || ('Punto ' + (lista.length + 1));
            var centro = map.getCenter();
            lista.push({ nombre: nombre, lat: centro.lat, lng: centro.lng, zoom: map.getZoom() });
            guardarMarcadoresGuardados(lista);
            input.value = '';
            renderMarcadores();
        });
        renderMarcadores();

        /* ==================================================================
           8. BARRA DE ESTADO INFERIOR
           ================================================================== */
        var modoCoordEstado = 'latlng';
        document.getElementById('status-left').addEventListener('click', function () {
            modoCoordEstado = modoCoordEstado === 'latlng' ? 'xy' : 'latlng';
        });
        map.on('mousemove', function (e) {
            var el = document.getElementById('status-left');
            if (modoCoordEstado === 'latlng') {
                el.textContent = e.latlng.lat.toFixed(6) + ', ' + e.latlng.lng.toFixed(6) + ' (Mouse)';
            } else {
                var p = L.CRS.EPSG3857.project(e.latlng);
                el.textContent = p.x.toFixed(2) + ', ' + p.y.toFixed(2) + ' (Mouse)';
            }
        });
        map.on('zoomend', function () { document.getElementById('status-zoom').textContent = 'Zoom ' + map.getZoom(); });
        document.getElementById('status-zoom').textContent = 'Zoom ' + map.getZoom();
    </script>
</body>
</html>
